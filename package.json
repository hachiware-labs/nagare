{
  "name": "@hachiware-labs/nagare-repo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "cargo build --workspace",
    "build:release": "cargo build --release -p nagare-cli",
    "test": "cargo test --workspace",
    "nagare": "node scripts/nagare-dev.js",
    "doctor": "node scripts/nagare-dev.js doctor",
    "init": "node scripts/nagare-dev.js init",
    "dev:scenario:first": "node scripts/nagare-dev.js dev scenario first",
    "pack:npm": "npm pack --workspace @hachiware-labs/nagare"
  }
}
